# ── LLM ────────────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Search ──────────────────────────────────────────────────────────────────────
# Get your key at https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ── Database ────────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
# In docker-compose this will be: postgresql+asyncpg://nexus:nexus@db:5432/nexus
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# ── Application ─────────────────────────────────────────────────────────────────
# "development" or "production"
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# Development default is the Vite dev server
CORS_ORIGINS=http://localhost:5173

# Swap to claude-sonnet-4-5 (or later) for production use
CLAUDE_MODEL=claude-haiku-4-5-20251001